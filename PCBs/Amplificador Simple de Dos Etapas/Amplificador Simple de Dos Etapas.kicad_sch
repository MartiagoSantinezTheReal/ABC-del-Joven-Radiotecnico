		)
		(uuid "6b41aa97-d66a-4789-9890-c8be57ad1079")
	)
	(text ".control\n  * 1. Ejecutar la simulacion (10ms da tiempo a que la onda se estabilice)\n  tran 10u 10m\n  \n  * 2. Medir voltajes (ignorar los primeros 2ms del arranque)\n  meas tran v_in_pp PP V(Entrada_-) FROM=2m\n  meas tran v_out_pp PP V(Salida_-) FROM=2m\n  \n  * 3. Calcular ganancia\n  let ganancia_calculada = v_out_pp / v_in_pp\n  \n  * 4. Crear un separador visual para la consola\n  echo \"\"\n  echo \"==================================================\"\n  echo \"      RESULTADOS DE RENDIMIENTO Y DISTORSION      \"\n  echo \"==================================================\"\n  \n  * 5. Imprimir la ganancia\n  print ganancia_calculada\n  \n  * 6. Calcular Distorsion Armonica Total (THD) a 1kHz\n  echo \"--------------------------------------------------\"\n  fourier 1k V(Salida_-)\n  \n  echo \"==================================================\"\n.endc"
		(exclude_from_sim no)
		(at 54.864 121.158 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "febf4943-a183-4287-9c1a-5407099572f2")
	)
