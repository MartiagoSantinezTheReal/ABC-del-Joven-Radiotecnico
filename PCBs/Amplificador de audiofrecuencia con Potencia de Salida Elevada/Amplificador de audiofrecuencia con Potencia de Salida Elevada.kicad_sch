				(size 1.27 1.27)
			)
		)
		(uuid "56b9f209-ce1f-4e53-8024-d7439caa9431")
	)
	(text ".control\n  * 1. Simulación extendida para permitir el asentamiento de los capacitores\n  tran 10u 200m\n  \n  * 2. Medir voltajes Pico a Pico en la ventana estable (150ms - 200ms)\n  meas tran v_in_pp PP V(IN) FROM=150m TO=200m\n  meas tran v_out_pp PP V(OUT) FROM=150m TO=200m\n  \n  * 3. Calcular Ganancia de Voltaje\n  let ganancia_calculada = v_out_pp / v_in_pp\n  \n  * 4. Calcular Potencia de Salida Útil (Audio AC)\n  * Fórmula: (Vpp^2) / (8 * RL). Con RL = 8 ohms, el divisor es 64.\n  let p_out = (v_out_pp * v_out_pp) / 64\n  \n  * 5. Medir Potencia DC consumida por la batería VB2 (12V)\n  meas tran i_dc_avg AVG I(VB2) FROM=150m TO=200m\n  let p_in_dc = 12 * abs(i_dc_avg)\n  \n  * 6. Calcular Eficiencia Real (%)\n  let eficiencia = (p_out / p_in_dc) * 100\n  \n  * 7. Imprimir Resultados en Consola\n  echo \"\"\n  echo \"==================================================\"\n  echo \"      RESULTADOS DE RENDIMIENTO (ESTADO ESTABLE)  \"\n  echo \"==================================================\"\n  echo \"Ganancia de Voltaje (Veces):\"\n  print ganancia_calculada\n  echo \"Potencia de Salida Util AC (Watts):\"\n  print p_out\n  echo \"Potencia DC Consumida (Watts):\"\n  print p_in_dc\n  echo \"Eficiencia Total (%):\"\n  print eficiencia\n  \n  echo \"--------------------------------------------------\"\n  echo \"Análisis de Fourier (Distorsión en estado estable):\"\n  fourier 1k V(OUT)\n  echo \"==================================================\"\n.endc"
		(exclude_from_sim no)
		(at 62.484 132.08 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "cbadef4d-eda9-4744-82cc-b40a729ff03c")
	)
